# ─── Base Neon (PostgreSQL) ───
# Avec le driver `pg` (Node), retire `channel_binding=require` si Neon te le propose — il est filtré automatiquement par le serveur.
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── JWT (min. 32 caractères en production) ───
JWT_SECRET=changez_moi_minimum_32_caracteres_secrets
JWT_REFRESH_SECRET=autre_secret_refresh_minimum_32_caracteres

# ─── CSRF (secret dédié ou réutilisation de JWT_SECRET côté dev) ───
CSRF_SECRET=changez_moi_minimum_32_caracteres_csrf

# ─── App ───
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# Cookies Secure (HTTPS) — en local mettre false si pas de TLS
SESSION_COOKIE_SECURE=false
